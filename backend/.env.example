# Database
DATABASE_URL=postgresql://medirag:changeme@localhost:5432/medirag

# BigQuery (MIMIC-III Data Access)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
MIMIC_DATASET=physionet-data.mimiciii_clinical

# Local LLM
LLM_MODEL_PATH=./data/models/llama-3-8b-instruct.gguf
LLM_CONTEXT_SIZE=4096
LLM_TEMPERATURE=0.3
LLM_GPU_LAYERS=35

# LLM Strategy & API Keys
LLM_STRATEGY=auto  # auto, gemini, openai, local, template

# Google Gemini API (FREE - Get key at: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash  # or gemini-1.5-pro
GEMINI_MAX_TOKENS=1000
GEMINI_TEMPERATURE=0.3

# OpenAI API (Paid - Get key at: https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000

# Vector Store
FAISS_INDEX_PATH=./data/processed/faiss_index/faiss.index
CORPUS_METADATA_PATH=./data/processed/corpus_metadata.json

# ML Models
ML_MODELS_PATH=./data/models/disease_models/

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Drug Interaction Database
DRUG_INTERACTIONS_PATH=./data/processed/drug_interactions.json

# API Settings
API_V1_PREFIX=/api/v1
PROJECT_NAME=MediRAG
VERSION=1.0.0
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO

